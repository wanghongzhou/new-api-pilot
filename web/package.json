{
  "name": "new-api-pilot-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "rsbuild dev",
    "routes:generate": "tsr generate",
    "build": "bun run routes:generate && rsbuild build",
    "build:app": "rsbuild build",
    "build:check": "bun run check",
    "typecheck": "tsgo -b",
    "lint": "oxlint -c .oxlintrc.json .",
    "lint:fix": "oxlint -c .oxlintrc.json . --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "i18n:check": "bun scripts/i18n-check.ts",
    "test:unit": "bun test src",
    "test:e2e": "playwright test",
    "check": "bun run routes:generate && bun run typecheck && bun run lint && bun run format:check && bun run i18n:check && bun run build:app",
    "preview": "rsbuild preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/public-sans": "^5.2.7",
