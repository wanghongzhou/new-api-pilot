# Production deployment. Copy to .env and replace every secret before running
# docker compose up -d. Development uses docker-compose.dev.yml and does not
# require this file.

API_IMAGE=new-api-pilot:local
API_PORT=3000

# Domestic build mirrors. Override with an internal registry when available.
BUN_IMAGE=docker.m.daocloud.io/oven/bun:1.3.13-alpine
GO_IMAGE=docker.m.daocloud.io/library/golang:1.25-alpine
RUNTIME_IMAGE=docker.m.daocloud.io/library/alpine:3.22
MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.4
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
GO_MODULE_PROXY=https://goproxy.cn,https://mirrors.aliyun.com/goproxy/,direct
GO_SUM_DATABASE=sum.golang.google.cn
ALPINE_MIRROR=https://mirrors.aliyun.com/alpine

# MySQL
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
MYSQL_DATABASE=new_api_pilot
MYSQL_USER=pilot
MYSQL_PASSWORD=replace-with-a-strong-application-password
DATABASE_DSN=pilot:replace-with-a-strong-application-password@tcp(mysql:3306)/new_api_pilot?charset=utf8mb4&parseTime=True&loc=Asia%2FShanghai
SQL_MAX_IDLE_CONNS=20
SQL_MAX_OPEN_CONNS=100
SQL_MAX_LIFETIME_SECONDS=60

# Redis
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_DSN=redis://:replace-with-a-strong-redis-password@redis:6379/0
REDIS_DB=0
REDIS_TIMEOUT_SECONDS=2

# Security secrets. Values are examples only; generate new Base64 values.
# SESSION_SECRET must decode to at least 32 bytes.
SESSION_SECRET=replace-with-base64-session-secret
# ENCRYPTION_KEY must decode to exactly 32 bytes.
ENCRYPTION_KEY=replace-with-base64-32-byte-encryption-key
# Optional one-time initial password; remove after the administrator is created.
PLATFORM_BOOTSTRAP_ADMIN_PASSWORD=

# Public HTTPS entry served by Caddy, Nginx, or another reverse proxy.
PUBLIC_ORIGIN=https://pilot.example.com
# Optional exact proxy IPs/CIDRs. Empty means forwarded client-IP headers are not trusted.
TRUSTED_PROXIES=

# Optional enterprise CA PEM mounted into the API container by the deployment.
UPSTREAM_CA_FILE=
# Optional additional DingTalk webhook hosts; oapi.dingtalk.com is always allowed.
DINGTALK_ALLOWED_HOSTS=
# Prometheus source networks allowed to access /metrics.
METRICS_ALLOWED_CIDRS=127.0.0.0/8,172.16.0.0/12
